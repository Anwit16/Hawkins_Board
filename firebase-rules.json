{
  "rules": {
    "rooms": {
      // Hard limit: max 500 rooms total in the database
      ".read": false,
      ".write": false,
      "$roomId": {
        // Room ID must be exactly 6 uppercase alphanumeric chars
        "meta": {
          ".read": true,
          ".write": "!data.exists() && $roomId.matches(/^[A-Z0-9]{6}$/)",
          ".validate": "newData.hasChildren(['name','pin','createdAt']) &&
                        newData.child('name').isString() &&
                        newData.child('name').val().length >= 1 &&
                        newData.child('name').val().length <= 64 &&
                        newData.child('pin').isString() &&
                        newData.child('pin').val().matches(/^[0-9]{4}$/) &&
                        newData.child('createdAt').isNumber() &&
                        newData.child('createdAt').val() >= now - 60000"
        },
        "session":   { ".read": true, ".write": true },
        "waiting": {
          ".read": true,
          "$uid": {
            ".write": true,
            ".validate": "newData.hasChildren(['name','ts']) &&
                          newData.child('name').isString() &&
                          newData.child('name').val().length >= 1 &&
                          newData.child('name').val().length <= 64 &&
                          newData.child('ts').isNumber()"
          }
        },
        "admitted":  { ".read": true, ".write": true },
        "kicked":    { ".read": true, ".write": true },
        "users": {
          ".read": true,
          "$uid": {
            ".write": true,
            ".validate": "newData.hasChildren(['name','ts']) &&
                          newData.child('name').isString() &&
                          newData.child('ts').isNumber()"
          }
        },
        "pagesMeta": { ".read": true, ".write": true },
        "morse": {
          ".read": true,
          "$mid": {
            ".write": true,
            ".validate": "newData.hasChildren(['x','y','ts']) &&
                          newData.child('ts').isNumber()"
          }
        },
        "lights":    { ".read": true, ".write": true },
        "pages": {
          "$pageId": {
            "strokes": {
              ".read": true,
              ".write": true,
              "$strokeId": {
                ".validate": "newData.hasChildren(['uid','pts','ts']) &&
                              newData.child('pts').isString() == false &&
                              newData.child('ts').isNumber() &&
                              newData.child('pts').val().length <= 5000"
              }
            },
            "cleared": { ".read": true, ".write": true }
          }
        }
      }
    }
  }
}
